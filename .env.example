# Copy to .env and fill in. docker-compose reads this file automatically.

# ---- Required ----
ANTHROPIC_API_KEY=
TAVILY_API_KEY=

# ---- Optional: cross-report disagreement graph ----
# Enables canonical claims + contradiction edges + prior-knowledge recall.
# If left blank, deep/basic reports work exactly as before and the graph layer
# stays dormant (fail-soft).
VOYAGE_API_KEY=

# ---- Auth ----
# REQUIRED in production. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# If unset in development, an ephemeral per-process secret is used (sessions
# don't survive restarts). In production (DEEPFIELD_ENV=production) a missing
# value is a hard error.
JWT_SECRET=

# ---- Deployment / runtime ----
# Set to "production" on your host to enforce JWT_SECRET and tighten defaults.
DEEPFIELD_ENV=development
# Comma-separated list of allowed browser origins (your deployed frontend URL),
# e.g. https://deepfield.up.railway.app  — leave blank for local dev ("*").
ALLOWED_ORIGINS=

# ---- Cost controls (deep runs only; basic/chat are unmetered) ----
# Per-user monthly deep-run allowance (resets on the 1st, UTC).
DEEPFIELD_FREE_DEEP_RUNS=3
# Hard global ceiling on total deep runs per day across ALL users — the wallet
# protector. Set to 0 to disable.
DEEPFIELD_GLOBAL_DAILY_DEEP_RUNS=50

# ---- Database ----
# Used when the backend runs outside docker. Inside docker-compose the backend
# gets DATABASE_URL pointing at the `db` service automatically. On a managed
# host (Railway/Render), set this to the platform-provided Postgres URL.
DATABASE_URL=postgresql://user:password@localhost:5432/deepfield
