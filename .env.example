# Copy to .env and fill in. docker-compose reads this file automatically.
ANTHROPIC_API_KEY=
TAVILY_API_KEY=
# Optional. Enables the cross-report disagreement graph (canonical claims +
# contradiction edges + prior-knowledge recall). If left blank, deep/basic
# reports work exactly as before and the graph layer stays dormant.
VOYAGE_API_KEY=
# Used by the backend when run outside docker. Inside docker-compose the
# backend gets DATABASE_URL pointing at the `db` service automatically.
DATABASE_URL=postgresql://user:password@localhost:5432/deepfield
